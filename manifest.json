{
    "name": "Universal Wish List",
    "version": "1.0",
    "description": "An extension for adding items to lists in Universal Wish List",
    "permissions": ["tabs", "storage"],
    "host_permissions": [
        "http://*/*",
        "https://*/*"
    ],
    "background": {
        "service_worker": "service-worker.js",
        "type": "module"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": "assets/Wishlist_logo.png"
    },
    "manifest_version": 3
}