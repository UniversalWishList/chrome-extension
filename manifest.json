{
    "name": "Universal Wish List",
    "version": "1.0",
    "description": "An extension for adding items to lists in Universal Wish List",
    "permissions": ["tabs", "storage"],
    "background": {
        "service_worker": "service-worker.js",
        "type": "module"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": "icon.png"
    },
    "manifest_version": 3,
    "options_ui": {
      "page": "options/options.html",
      "open_in_tab": true
    }
}