{
    "name": "Universal Wish List",
    "version": "1.0",
    "description": "An extension for adding items to lists in Universal Wish List",
    "permissions": ["activeTab"],
    "background": {
        "service_worker": "service-worker.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    },
    "manifest_version": 3
}